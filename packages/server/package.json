{
  "name": "@salesagent/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:schemas": "vitest run src/schemas/zodSchemaCoverage.spec.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:generate": "npm run build && drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.migrate.config.ts",
    "db:check": "npm run build && drizzle-kit check --config=drizzle.config.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@bull-board/api": "^6.20.3",
    "@bull-board/fastify": "^6.20.3",
    "@fastify/cookie": "^11.0.2",
    "@fastify/session": "^11.1.1",
    "@fastify/websocket": "^11.2.0",
    "@guardian/google-admanager-api": "^6.0.3",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "bullmq": "^5.70.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.7.4",
    "fastify-type-provider-zod": "^6.1.0",
    "ioredis": "^5.9.3",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
